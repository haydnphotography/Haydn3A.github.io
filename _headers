# ============================================================
#  Netlify _headers — HTTP Security Headers
#  These apply when hosting on Netlify.
#  For GitHub Pages, see the README for workaround options.
# ============================================================

/*
  # Prevent clickjacking
  X-Frame-Options: DENY

  # Prevent MIME sniffing
  X-Content-Type-Options: nosniff

  # Referrer policy — don't leak your URL to third parties
  Referrer-Policy: strict-origin-when-cross-origin

  # Content Security Policy
  # Adjust if you add external scripts/fonts
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';

  # Permissions policy — disable unused browser features
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()

  # Strict Transport Security — force HTTPS
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Prevent caching of HTML to ensure latest version is served
  Cache-Control: no-cache, no-store, must-revalidate

/style.css
  Cache-Control: public, max-age=604800, immutable

/app.js
  Cache-Control: public, max-age=604800, immutable

/photos.js
  Cache-Control: public, max-age=86400

/images/*
  Cache-Control: public, max-age=2592000, immutable
